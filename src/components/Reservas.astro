<section id="reservas" class="py-32 relative overflow-hidden bg-dark">
    <!-- Decorative background elements -->
    <div class="absolute inset-0 bg-[radial-gradient(circle_at_50%_50%,rgba(243,208,99,0.05)_0%,transparent_70%)]"></div>
    
    <div class="container mx-auto px-4 text-center space-y-12 relative z-10 animate-entrance">
        <div class="space-y-4">
            <h2 class="text-primary text-6xl md:text-8xl font-black uppercase tracking-tighter mb-2">Reservas</h2>
            <div class="h-1 w-32 bg-primary mx-auto"></div>
        </div>
        
        <p class="text-text/60 text-xl md:text-3xl font-body max-w-3xl mx-auto italic font-light leading-relaxed">
            "Asegura tu mesa en el santuario del sabor arequipeño y vive una experiencia tallada en tradición."
        </p>
        
        <div class="flex flex-col items-center justify-center gap-10 pt-12">
            <a 
                href="https://wa.me/51955053124?text=Hola%20quisiera%20hacer%20una%20reserva%20en%20Wasi%20Mikuna" 
                target="_blank"
                class="stone-panel px-16 py-8 border-primary/40 hover:border-primary transition-all duration-700 group relative overflow-hidden"
            >
                <div class="absolute inset-0 bg-primary opacity-0 group-hover:opacity-5 transition-opacity"></div>
                <div class="flex items-center gap-6">
                    <div class="w-16 h-16 border border-primary/30 flex items-center justify-center rounded-full group-hover:scale-110 transition-transform duration-500">
                        <svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8 text-primary" viewBox="0 0 24 24" fill="currentColor">
                            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/>
                        </svg>
                    </div>
                    <div class="text-left">
                        <p class="text-primary font-heading font-black text-2xl tracking-widest uppercase">WhatsApp</p>
                        <p class="text-text/40 text-sm">Reserva inmediata</p>
                    </div>
                </div>
            </a>
            
            <div class="space-y-4 animate-scale-in">
                <p class="text-text/30 font-heading tracking-[0.5em] uppercase text-xs">Atención al Cliente</p>
                <p class="text-primary text-4xl md:text-5xl font-black">+51 955053124</p>
            </div>
        </div>
    </div>
</section>

<style>
    section {
        background-image: url("https://www.transparenttextures.com/patterns/cream-paper.png");
    }
</style>
