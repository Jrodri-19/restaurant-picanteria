---
import menuData from '../data/menu.json';
---

<section id="menu" class="py-24 relative overflow-hidden">
    <!-- Section Header -->
    <div class="relative z-10 container mx-auto px-4 mb-20 text-center animate-entrance">
        <h2 class="text-5xl md:text-7xl mb-4">Nuestra Carta</h2>
        <div class="h-1 w-24 bg-primary mx-auto"></div>
    </div>

    <div class="container mx-auto px-4 relative z-10">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-16">
            {menuData.categories.map((category, idx) => (
                <div class={`stone-panel p-8 md:p-12 space-y-8 group hover:border-primary/40 transition-all duration-700 ${idx % 2 === 0 ? 'lg:translate-y-8' : ''}`}>
                    <div class="flex items-center gap-4">
                        <span class="text-primary/20 text-4xl font-heading">0{idx + 1}</span>
                        <h3 class="text-3xl md:text-4xl">{category.name}</h3>
                    </div>

                    <div class="space-y-6">
                        {category.items.map((item) => (
                            <div class="group/item">
                                <div class="flex justify-between items-baseline gap-4 mb-1">
                                    <h4 class="text-xl md:text-2xl font-bold text-text/90 group-hover/item:text-primary transition-colors">
                                        {item.name}
                                    </h4>
                                    
                                </div>
                                {item.description && (
                                    <p class="text-sm md:text-base text-text/50 font-light italic leading-tight">
                                        {item.description}
                                    </p>
                                )}
                            </div>
                        ))}
                    </div>
                    
                    <!-- Decorative element for each panel -->
                    <div class="absolute -bottom-4 -right-4 w-24 h-24 text-primary/5 rotate-12 group-hover:rotate-0 transition-transform duration-1000">
                        <svg viewBox="0 0 100 100" class="fill-current">
                            <path d="M50 0 L100 50 L50 100 L0 50 Z" />
                        </svg>
                    </div>
                </div>
            ))}
        </div>
    </div>
</section>

<style>
    #menu {
        background: radial-gradient(circle at 50% 0%, #1a1a1a 0%, #0c0c0c 100%);
    }
</style>
