---
---

<footer class="bg-dark border-t border-primary/10 relative overflow-hidden">
  <!-- Texture Overlay -->
  <div class="absolute inset-0 bg-[url('https://www.transparenttextures.com/patterns/dark-matter.png')] opacity-30 pointer-events-none"></div>
  
  <div
    class="max-w-7xl mx-auto px-6 py-20 grid grid-cols-1 md:grid-cols-3 gap-16 relative z-10"
  >
    <!-- Marca -->
    <div class="space-y-6">
      <div class="flex items-center gap-4">
        <img src="/logo.png" alt="WASIMIKUNA" class="h-16 w-auto" />
        <div class="font-heading">
          <h3 class="text-primary text-3xl font-black tracking-tighter uppercase">WASI MIKUNA</h3>
          <p class="text-primary/40 text-[10px] tracking-[0.4em] uppercase">Picantería Arequipeña</p>
        </div>
      </div>

      <p class="text-text/50 text-sm leading-relaxed font-body max-w-sm">
        Somos parte de la más pura tradición arequipeña. Cocina loncca, fogón
        encendido y sabor que se respeta, desde Socabaya para la mesa.
      </p>

      <!-- Redes -->
      <div class="flex flex-wrap gap-3 mt-8">
        {[
          { href: "https://web.facebook.com/profile.php?id=61586922926238", label: "Facebook", path: "M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z" },
