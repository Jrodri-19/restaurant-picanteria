        ].map((social) => (
          <a
            href={social.href}
            target="_blank"
            rel="noopener"
            aria-label={social.label}
            class="w-10 h-10 border border-primary/20 flex items-center justify-center text-primary hover:bg-primary hover:text-dark transition-all duration-500 rounded-none group/icon"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              viewBox="0 0 24 24"
              fill="currentColor"
              class="w-5 h-5 group-hover/icon:scale-110 transition-transform"
            >
              <path d={social.path}></path>
            </svg>
          </a>
        ))}
        <!-- Kick Special Logo -->
        <a href="https://kick.com/wasimikuna-picanteria" target="_blank" rel="noopener" aria-label="Kick" class="w-10 h-10 border border-primary/20 flex items-center justify-center text-primary hover:bg-primary hover:text-dark transition-all duration-500 rounded-none group/icon">
            <svg viewBox="0 0 933 300" fill="currentColor" class="w-6 h-6 group-hover/icon:scale-110 transition-transform">
                <path fill-rule="evenodd" clip-rule="evenodd" d="M0 0H100V66.6667H133.333V33.3333H166.667V0H266.667V100H233.333V133.333H200V166.667H233.333V200H266.667V300H166.667V266.667H133.333V233.333H100V300H0V0ZM666.667 0H766.667V66.6667H800V33.3333H833.333V0H933.333V100H900V133.333H866.667V166.667H900V200H933.333V300H833.333V266.667H800V233.333H766.667V300H666.667V0ZM300 0H400V300H300V0ZM533.333 0H466.667V33.3333H433.333V266.667H466.667V300H533.333H633.333V200H533.333V100H633.333V0H533.333Z" />
            </svg>
        </a>
      </div>
    </div>

    <!-- Enlaces -->
    <div class="space-y-8">
      <h4 class="text-primary font-heading font-black text-lg tracking-widest uppercase italic">Enlaces Importantes</h4>

      <ul class="space-y-4 text-sm font-body">
        {['Inicio', 'Carta', 'Reservas', 'Contacto'].map((item) => (
            <li>
                <a href={item === 'Inicio' ? '/' : `/${item.toLowerCase()}`} class="text-text/60 hover:text-primary transition-all duration-300 uppercase tracking-widest flex items-center gap-2 group">
                    <span class="w-0 h-px bg-primary group-hover:w-4 transition-all"></span>
                    {item}
                </a>
            </li>
        ))}
      </ul>
    </div>

    <!-- Contacto -->
    <div class="space-y-8">
      <h4 class="text-primary font-heading font-black text-lg tracking-widest uppercase italic">Contacto</h4>

      <div class="space-y-6 text-sm font-body">
        <a
          href="https://maps.app.goo.gl/JK5NVcbMWw9kAYny8"
          target="_blank"
          rel="noopener"
          class="text-text/60 hover:text-primary transition-all flex items-start gap-3"
        >
          <span class="text-primary">📍</span>
          <span>La Paisajista - Socabaya – Arequipa<br />🇵🇪 Perú</span>
        </a>

        <a
          href="https://wa.me/51955053124?text=Hola,%20quisiera%20realizar%20un%20pedido"
          target="_blank"
          rel="noopener"
          class="text-text/60 hover:text-primary transition-all flex items-center gap-3"
        >
          <span class="text-primary">📞</span>
          <span>Pedidos por WhatsApp</span>
        </a>

        <a
            href="https://wa.me/51955053124"
            target="_blank"
            rel="noopener"
            class="inline-block mt-4 bg-primary text-dark px-10 py-4 text-[10px] font-heading font-black tracking-[0.3em] hover:bg-white transition-all duration-500 shadow-[0_0_20px_rgba(243,208,99,0.2)] uppercase"
        >
            Escríbenos
        </a>
      </div>
    </div>
  </div>

  <!-- Barra inferior -->
  <div class="bg-primary text-dark text-center py-8 text-[10px] tracking-[0.5em] uppercase font-heading font-black relative z-10">
    © {new Date().getFullYear()} Wasi Mikuna — Picantería Arequipeña
  </div>
</footer>
