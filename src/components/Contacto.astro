---
---
<section id="contacto" class="py-32 relative overflow-hidden bg-dark">
    <!-- Texture Overlay -->
    <div class="absolute inset-0 bg-[url('https://www.transparenttextures.com/patterns/dark-matter.png')] opacity-30 pointer-events-none"></div>
    
    <div class="container mx-auto px-4 relative z-10 space-y-20 animate-entrance">
        <div class="text-center space-y-4">
            <h2 class="text-primary text-5xl md:text-7xl font-black uppercase tracking-tighter italic">Contacto</h2>
            <div class="h-1 w-32 bg-primary mx-auto"></div>
        </div>
        
        <div class="grid grid-cols-1 md:grid-cols-3 gap-16">
            <!-- Dirección -->
            <div class="stone-panel p-12 text-center group hover:border-primary/50 transition-all duration-700 space-y-8">
                <div class="w-20 h-20 border border-primary/20 flex items-center justify-center mx-auto group-hover:scale-110 transition-transform duration-700 bg-primary/5">
                    <svg xmlns="http://www.w3.org/2000/svg" class="w-10 h-10 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                    </svg>
                </div>
                <div class="space-y-4">
                    <h3 class="text-primary font-heading font-black text-2xl uppercase tracking-widest italic">Visítanos</h3>
                    <p class="text-text/60 font-body leading-relaxed">
                        La Paisajista - Socabaya<br />Arequipa, Perú
                    </p>
                    <a 
                        href="https://maps.app.goo.gl/JK5NVcbMWw9kAYny8" 
                        target="_blank" 
                        class="inline-block text-primary text-xs font-heading font-bold uppercase tracking-widest hover:text-white transition-colors"
                    >
                        Ver en Google Maps →
                    </a>
                </div>
            </div>

            <!-- WhatsApp & Pedidos -->
            <div class="stone-panel p-12 text-center group border-primary/40 hover:border-primary transition-all duration-700 space-y-8">
                <div class="w-20 h-20 border border-primary/20 flex items-center justify-center mx-auto group-hover:scale-110 transition-transform duration-700 bg-primary/5">
                    <svg xmlns="http://www.w3.org/2000/svg" class="w-10 h-10 text-primary" viewBox="0 0 24 24" fill="currentColor">
                        <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/>
                    </svg>
                </div>
                <div class="space-y-4">
                    <h3 class="text-primary font-heading font-black text-2xl uppercase tracking-widest italic">WhatsApp</h3>
                    <p class="text-text/60 font-body leading-relaxed">
                        Pedidos y consultas rápidas<br />+51 955053124
                    </p>
                    <a 
                        href="https://wa.me/51955053124?text=Hola,%20quisiera%20realizar%20un%20pedido" 
                        target="_blank" 
                        class="inline-block bg-primary text-dark px-8 py-3 text-[10px] font-heading font-black tracking-widest hover:bg-white transition-all duration-500 uppercase"
                    >
                        Escríbenos →
                    </a>
                </div>
            </div>

            <!-- Redes Sociales -->
            <div class="stone-panel p-12 text-center group hover:border-primary/50 transition-all duration-700 space-y-8">
                <div class="w-20 h-20 border border-primary/20 flex items-center justify-center mx-auto group-hover:scale-110 transition-transform duration-700 bg-primary/5">
                    <svg xmlns="http://www.w3.org/2000/svg" class="w-10 h-10 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101" />
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M10.172 13.828a4 4 0 015.656 0l4 4a4 4 0 11-5.656 5.656l-1.101-1.101" />
                    </svg>
                </div>
                <div class="space-y-6">
                    <h3 class="text-primary font-heading font-black text-2xl uppercase tracking-widest italic">Síguenos</h3>
                    <div class="flex flex-col gap-4 text-sm">
                        <a 
                            href="https://web.facebook.com/profile.php?id=61586922926238" 
                            target="_blank" 
                            class="text-text/60 hover:text-primary transition-all flex items-center justify-center gap-2 group/link"
                        >
                            <span class="w-0 h-px bg-primary group-hover/link:w-4 transition-all"></span>
                            Facebook
                        </a>
                        <a 
                            href="https://www.instagram.com/wasimikuna.picanteria/" 
                            target="_blank" 
                            class="text-text/60 hover:text-primary transition-all flex items-center justify-center gap-2 group/link"
                        >
                            <span class="w-0 h-px bg-primary group-hover/link:w-4 transition-all"></span>
                            Instagram
                        </a>
                        <a 
                            href="https://www.tiktok.com/@wasimikuna.picanteria" 
                            target="_blank" 
                            class="text-text/60 hover:text-primary transition-all flex items-center justify-center gap-2 group/link"
                        >
                            <span class="w-0 h-px bg-primary group-hover/link:w-4 transition-all"></span>
                            TikTok
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
